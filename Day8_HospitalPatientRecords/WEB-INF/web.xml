<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Hospital Patient Records</display-name>

    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>controllers.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controllers.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controllers.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>controllers.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AiInsightsServlet</servlet-name>
        <servlet-class>controllers.AiInsightsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AiInsightsServlet</servlet-name>
        <url-pattern>/ai-insights</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterPatientServlet</servlet-name>
        <servlet-class>controllers.RegisterPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterPatientServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientListServlet</servlet-name>
        <servlet-class>controllers.PatientListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientListServlet</servlet-name>
        <url-pattern>/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientDetailServlet</servlet-name>
        <servlet-class>controllers.PatientDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientDetailServlet</servlet-name>
        <url-pattern>/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditPatientServlet</servlet-name>
        <servlet-class>controllers.EditPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditPatientServlet</servlet-name>
        <url-pattern>/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DischargePatientServlet</servlet-name>
        <servlet-class>controllers.DischargePatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DischargePatientServlet</servlet-name>
        <url-pattern>/discharge</url-pattern>
    </servlet-mapping>

</web-app>
